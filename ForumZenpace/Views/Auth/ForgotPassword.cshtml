@model ForumZenpace.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="auth-shell animated-entry">
    <div class="surface auth-card">
        <div class="auth-header">
            <div class="auth-mark">
                <i class="fa-solid fa-key"></i>
            </div>
            <h1 class="auth-title">Hỗ trợ đặt lại mật khẩu</h1>
            <p class="auth-subtitle">Nhập tên tài khoản hoặc email đã đăng ký. Nếu thông tin hợp lệ, hệ thống sẽ gửi OTP đặt lại mật khẩu.</p>
        </div>

        @if (TempData["AuthSuccessMessage"] is string authSuccessMessage)
        {
            <div class="auth-inline-alert mb-3">
                <i class="fa-solid fa-circle-check"></i>
                <span>@authSuccessMessage</span>
            </div>
        }

        @if (TempData["AuthErrorMessage"] is string authErrorMessage)
        {
            <div class="auth-inline-alert is-error mb-3">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span>@authErrorMessage</span>
            </div>
        }

        <form asp-action="ForgotPassword" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2 text-center"></div>

            <div class="field">
                <label asp-for="Identifier" class="field-label">Tên tài khoản hoặc email</label>
                <div class="input-icon">
                    <i class="fa-solid fa-envelope"></i>
                    <input asp-for="Identifier" class="form-control" placeholder="username hoặc email" />
                </div>
                <span asp-validation-for="Identifier" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%;">Gửi OTP đặt lại mật khẩu</button>

            <div class="auth-footer">
                Muốn quay lại?
                <a asp-action="Login">Trang đăng nhập</a>
            </div>
        </form>
    </div>
</div>
