@model ForumZenpace.Models.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="auth-shell auth-shell--wide animated-entry">
    <div class="surface auth-card">
        <div class="auth-header">
            <div class="auth-mark">
                <i class="fa-solid fa-user-plus"></i>
            </div>
            <h1 class="auth-title">Tạo tài khoản mới</h1>
            <p class="auth-subtitle">Sau khi nhập email và gửi form, hệ thống sẽ mở bước xác thực OTP. Chỉ khi nhập đúng mã OTP, tài khoản mới được tạo.</p>
        </div>

        @if (TempData["AuthSuccessMessage"] is string authSuccessMessage)
        {
            <div class="auth-inline-alert mb-3">
                <i class="fa-solid fa-circle-check"></i>
                <span>@authSuccessMessage</span>
            </div>
        }

        @if (TempData["AuthErrorMessage"] is string authErrorMessage)
        {
            <div class="auth-inline-alert is-error mb-3">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span>@authErrorMessage</span>
            </div>
        }

        <form asp-action="Register" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2 text-center"></div>

            <div class="form-grid-2">
                <div class="field">
                    <label asp-for="Username" class="field-label">Tên tài khoản</label>
                    <input asp-for="Username" class="form-control" placeholder="username" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="field">
                    <label asp-for="FullName" class="field-label">Họ tên</label>
                    <input asp-for="FullName" class="form-control" placeholder="Họ tên của bạn" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>
            </div>

            <div class="field">
                <label asp-for="Email" class="field-label">Email</label>
                <div class="input-icon">
                    <i class="fa-solid fa-envelope"></i>
                    <input asp-for="Email" class="form-control" type="email" placeholder="example@zenpace.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-grid-2">
                <div class="field">
                    <label asp-for="Password" class="field-label">Mật khẩu</label>
                    <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="field">
                    <label asp-for="ConfirmPassword" class="field-label">Xác nhận</label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%;">Tạo tài khoản</button>

            <div class="auth-footer">
                Đã có tài khoản?
                <a asp-action="Login">Đăng nhập</a>
            </div>
        </form>
    </div>
</div>
