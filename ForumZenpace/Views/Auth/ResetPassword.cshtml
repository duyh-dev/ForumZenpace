@model ForumZenpace.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="auth-shell auth-shell--wide animated-entry">
    <div class="surface auth-card">
        <div class="auth-header">
            <div class="auth-mark">
                <i class="fa-solid fa-unlock-keyhole"></i>
            </div>
            <h1 class="auth-title">Đặt lại mật khẩu bằng OTP</h1>
            <p class="auth-subtitle">Nhập mã OTP đã gửi tới email @Model.EmailMask và đặt mật khẩu mới cho tài khoản của bạn.</p>
        </div>

        @if (TempData["AuthSuccessMessage"] is string authSuccessMessage)
        {
            <div class="auth-inline-alert mb-3">
                <i class="fa-solid fa-circle-check"></i>
                <span>@authSuccessMessage</span>
            </div>
        }

        @if (TempData["AuthErrorMessage"] is string authErrorMessage)
        {
            <div class="auth-inline-alert is-error mb-3">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span>@authErrorMessage</span>
            </div>
        }

        <form asp-action="ResetPassword" method="post" class="auth-form">
            <input asp-for="FlowToken" type="hidden" />
            <input asp-for="EmailMask" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-2 text-center"></div>

            <div class="field">
                <label asp-for="OtpCode" class="field-label">Mã OTP</label>
                <div class="input-icon">
                    <i class="fa-solid fa-key"></i>
                    <input asp-for="OtpCode" class="form-control" inputmode="numeric" autocomplete="one-time-code" maxlength="6" placeholder="Nhập 6 chữ số" />
                </div>
                <span asp-validation-for="OtpCode" class="text-danger"></span>
            </div>

            <div class="form-grid-2">
                <div class="field">
                    <label asp-for="NewPassword" class="field-label">Mật khẩu mới</label>
                    <input asp-for="NewPassword" class="form-control" type="password" placeholder="Mật khẩu mới" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="field">
                    <label asp-for="ConfirmPassword" class="field-label">Xác nhận</label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Nhập lại mật khẩu mới" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%;">Đặt lại mật khẩu</button>
        </form>

        <form asp-action="ResendPasswordResetOtp" method="post" class="auth-form" style="margin-top: 12px;">
            <input type="hidden" name="flowToken" value="@Model.FlowToken" />
            <button type="submit" class="btn btn-outline" style="width: 100%;">Gửi lại mã OTP</button>
        </form>

        <div class="auth-footer">
            Muốn quay lại?
            <a asp-action="Login">Trang đăng nhập</a>
        </div>
    </div>
</div>
