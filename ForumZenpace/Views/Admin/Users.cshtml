@model IEnumerable<ForumZenpace.Models.User>
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="admin-shell animated-entry">
    <div class="admin-header">
        <div>
            <h1 class="admin-title">Quản lý hội viên</h1>
            <p class="admin-subtitle">Bảng user đã được đưa về compact table để hiển thị được nhiều dòng hơn trên màn hình desktop.</p>
        </div>

        <a asp-action="Dashboard" class="btn btn-outline">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="surface admin-table-shell">
        <div class="scroll-x">
            <table class="table">
                <thead>
                    <tr>
                        <th>Danh tính</th>
                        <th>Họ tên</th>
                        <th>Vai trò</th>
                        <th>Trạng thái</th>
                        <th>Gia nhập</th>
                        <th>Điều khiển</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td><strong>@@@user.Username</strong></td>
                            <td>@user.FullName</td>
                            <td>
                                <span class="badge-tag">@user.Role.Name</span>
                            </td>
                            <td>
                                <span class="status-pill @(user.IsActive ? "is-live" : "is-muted")">
                                    <span class="dot" style="background: currentColor;"></span>
                                    @(user.IsActive ? "Kích hoạt" : "Bị khóa")
                                </span>
                            </td>
                            <td class="table-note">@user.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                @if (user.Role.Name != "Admin")
                                {
                                    <form asp-action="ToggleUserStatus" method="post" class="inline-form">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn btn-outline">
                                            @(user.IsActive ? "Vô hiệu hóa" : "Kích hoạt")
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
